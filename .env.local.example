# ─────────────────────────────────────────────────────────────────────────────
# Nexora Studio — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file to `.env.local` (same directory)
# 2. Fill in your real values below
# 3. Restart `npm run dev` (env vars are only loaded on server start)
#
# ⚠️  NEVER commit `.env.local` — it's already in .gitignore.
# ⚠️  Vars MUST start with VITE_ to be visible to the React app.
# ─────────────────────────────────────────────────────────────────────────────

# Formspree — receives the contact form submission and emails you + auto-replies
# Get yours at https://formspree.io → New Form → copy endpoint URL
# Example: https://formspree.io/f/xqkrljgp
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORMSPREE_ID

# Telegram Bot — instant push notification to your phone on new lead
# 1. Telegram → @BotFather → /newbot → save the token
# 2. Message the bot once, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    → copy the numeric "chat":{"id":...} value
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=
